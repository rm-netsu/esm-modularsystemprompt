{
	"name": "@rm-netsu/esm-modularsystemprompt",
	"version": "0.1.1",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "public"
	},
	"scripts": {
		"build": "bun build src/index.ts --outdir=dist --target=node --format=esm --minify --sourcemap && bunx tsc --declaration --emitDeclarationOnly --outDir dist",
		"build:browser": "bun build src/index.ts --outdir=dist --target=browser --format=esm --minify --sourcemap && bunx tsc --declaration --emitDeclarationOnly --outDir dist",
		"build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --apply ."
	},
	"dependencies": {
		"@xmldom/xmldom": "^0.9.9"
	},
	"peerDependencies": {
		"@rm-netsu/esm-chatcompletions-client": "^0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rm-netsu/esm-modularsystemprompt.git"
	},
	"author": "rm-netsu",
	"engines": {
		"node": ">=18.0.0",
		"bun": ">=1.0.0"
	}
}
